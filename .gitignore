# Dependencies
node_modules/

# Build artifacts
dist/
*.tsbuildinfo

# Wrangler local state and dev secrets
.wrangler/
.dev.vars
.dev.vars.*

# Local env files (.env.example is the only one that should be tracked)
.env
.env.*
!.env.example

# Local-only credentials and tokens (never commit)
.turso-token
*.pem
*.key

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

